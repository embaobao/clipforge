{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipForge",
  "version": "0.1.0",
  "identifier": "app.clipforge.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ClipForge",
        "width": 420,
        "height": 400,
        "minWidth": 420,
        "minHeight": 320,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "hiddenTitle": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "ClipForge 设置",
        "url": "settings.html",
        "width": 720,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "hiddenTitle": false,
        "alwaysOnTop": false,
        "visibleOnAllWorkspaces": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$HOME/Library/Application Support/ClipForge/**",
          "$HOME/.config/clipforge/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../release-assets/CLIPFORGE_MUST_READ.html"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "CLIPFORGE_UPDATER_PUBLIC_KEY_NOT_CONFIGURED",
      "endpoints": [
        "https://github.com/embaobao/clipforge/releases/latest/download/latest.json"
      ]
    }
  }
}
