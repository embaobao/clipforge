{
  "name": "clipforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite",
    "build:web": "tsc && vite build",
    "check:i18n": "node scripts/check-i18n-keys.mjs && node scripts/scan-hardcoded-copy.mjs",
    "test:unit": "node scripts/run-unit-checks.mjs && node scripts/verify-agent-panel.mjs && node scripts/verify-editor-agent-bridge.mjs && node scripts/verify-runtime-boundaries.mjs && node scripts/verify-hot-path.mjs && node scripts/verify-mcp-dispatch.mjs && node scripts/verify-file-size.mjs",
    "test:agent": "node scripts/verify-agent-panel.mjs",
    "test:boundaries": "node scripts/verify-hot-path.mjs && node scripts/verify-runtime-boundaries.mjs && node scripts/verify-file-size.mjs",
    "build:manual": "node scripts/generate-release-manual.mjs",
    "build": "bash ./scripts/build-mac-release.sh",
    "build:mac-release": "bash ./scripts/build-mac-release.sh",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.20",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@shadcn/react": "^0.2.1",
    "@tanstack/react-router": "^1.170.17",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "pinyin-pro": "^3.28.1",
    "radix-ui": "^1.6.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
